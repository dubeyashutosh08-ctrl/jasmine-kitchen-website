<style>

/* GLOBAL */

html{
scroll-behavior:smooth;
}

body{
margin:0;
font-family:'Poppins',sans-serif;
background:black;
color:white;
}

img{
max-width:100%;
height:auto;
display:block;
}

section{
margin-bottom:20px;
}

/* HEADER */

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:15px 30px;
border-bottom:2px solid gold;
position:sticky;
top:0;
background:black;
z-index:1000;
}

.logo{
color:gold;
font-size:24px;
font-weight:700;
letter-spacing:1px;
}

nav{
display:flex;
flex-wrap:wrap;
}

nav a{
color:white;
margin:10px;
text-decoration:none;
font-weight:500;
transition:color 0.3s ease;
position:relative;
}

nav a:hover{
color:gold;
}

nav a::after{
content:"";
position:absolute;
width:0%;
height:2px;
background:gold;
left:0;
bottom:-5px;
transition:0.3s;
}

nav a:hover::after{
width:100%;
}

.active{
color:gold;
}

/* HERO */

.hero{
text-align:center;
padding:70px 20px;
}

.hero h1{
color:gold;
font-size:42px;
margin-bottom:10px;
}

.hero p{
opacity:0.9;
font-size:16px;
}

/* BRANCH SECTION */

.branches{
max-width:1100px;
margin:auto;
padding:40px 30px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:30px;
}

.branch-card{
background:#111;
border:1px solid gold;
border-radius:12px;
overflow:hidden;
transition:transform 0.3s ease, box-shadow 0.3s ease;
cursor:pointer;
}

.branch-card:hover{
transform:translateY(-6px) scale(1.03);
box-shadow:0 0 20px rgba(255,215,0,0.6);
}

.branch-card img{
width:100%;
height:180px;
object-fit:cover;
}

.branch-info{
padding:18px;
}

.branch-info h3{
color:gold;
margin:0 0 10px 0;
font-size:18px;
}

.branch-info p{
font-size:14px;
margin:6px 0;
opacity:0.9;
}

/* CLICKABLE CONTACT LINKS */

.branch-info a,
footer a{
color:gold;
text-decoration:none;
}

.branch-info a:hover,
footer a:hover{
text-decoration:underline;
}

/* DELIVERY AREA */

.delivery{
text-align:center;
margin-top:10px;
font-weight:500;
color:gold;
font-size:16px;
}

/* MAP */

.map{
max-width:1000px;
margin:40px auto;
padding:20px;
}

.map iframe{
width:100%;
height:360px;
border:0;
border-radius:12px;
box-shadow:0 0 15px rgba(255,215,0,0.4);
}

/* FOOTER */

footer{
text-align:center;
padding:30px;
border-top:2px solid gold;
margin-top:40px;
font-size:14px;
background:#080808;
}

footer p{
margin:6px 0;
opacity:0.9;
}

/* MOBILE */

@media(max-width:768px){

header{
flex-direction:column;
text-align:center;
}

nav{
justify-content:center;
}

.hero h1{
font-size:30px;
}

.branches{
padding:25px;
}

}

</style>

</head>

